"use client";

import { useActionState } from "react";
import Link from "next/link";
import { HARI_LIST, HARI_LABEL } from "@/lib/constants";
import type { SlotFormState } from "./actions";

type Props = {
  action: (state: SlotFormState, formData: FormData) => Promise<SlotFormState>;
  defaultValues?: {
    hari: string;
    urutan: number;
    namaSlot: string;
    jenisSlot: string;
    jamMulai: string | null;
    jamSelesai: string | null;
  };
  submitLabel: string;
};

export default function SlotForm({ action, defaultValues, submitLabel }: Props) {
  const [state, formAction, pending] = useActionState<SlotFormState, FormData>(
    action,
    {}
  );

  return (
    <form action={formAction} className="max-w-xl space-y-5">
      {state.error && (
        <div className="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
          {state.error}
        </div>
      )}

      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-sm font-medium text-zinc-700 mb-1">Hari</label>
          <select
            name="hari"
            defaultValue={defaultValues?.hari ?? "SENIN"}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none"
          >
            {HARI_LIST.map((h) => (
              <option key={h} value={h}>
                {HARI_LABEL[h]}
              </option>
            ))}
          </select>
        </div>
        <div>
          <label className="block text-sm font-medium text-zinc-700 mb-1">
            Urutan
          </label>
          <input
            name="urutan"
            type="number"
            min={1}
            defaultValue={defaultValues?.urutan ?? 1}
            required
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none"
          />
        </div>
      </div>

      <div>
        <label className="block text-sm font-medium text-zinc-700 mb-1">
          Nama Slot
        </label>
        <input
          name="namaSlot"
          defaultValue={defaultValues?.namaSlot}
          placeholder="Contoh: JP 1, Istirahat, Upacara"
          required
          className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none"
        />
      </div>

      <div>
        <label className="block text-sm font-medium text-zinc-700 mb-1">
          Jenis Slot
        </label>
        <select
          name="jenisSlot"
          defaultValue={defaultValues?.jenisSlot ?? "PELAJARAN"}
          className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none"
        >
          <option value="PELAJARAN">Pelajaran</option>
          <option value="NON_PELAJARAN">Non-Pelajaran (Istirahat/Upacara/dll)</option>
        </select>
      </div>

      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-sm font-medium text-zinc-700 mb-1">
            Jam Mulai (Opsional)
          </label>
          <input
            name="jamMulai"
            type="time"
            defaultValue={defaultValues?.jamMulai ?? ""}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none"
          />
        </div>
        <div>
          <label className="block text-sm font-medium text-zinc-700 mb-1">
            Jam Selesai (Opsional)
          </label>
          <input
            name="jamSelesai"
            type="time"
            defaultValue={defaultValues?.jamSelesai ?? ""}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none"
          />
        </div>
      </div>

      <div className="flex items-center gap-3 pt-2">
        <button
          type="submit"
          disabled={pending}
          className="rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-800 disabled:opacity-50"
        >
          {pending ? "Menyimpan..." : submitLabel}
        </button>
        <Link
          href="/admin/master/slot-waktu"
          className="text-sm text-zinc-600 hover:underline"
        >
          Batal
        </Link>
      </div>
    </form>
  );
}
